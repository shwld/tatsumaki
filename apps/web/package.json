{
  "name": "tatsumaki-web",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "overrides": {
    "esbuild": "0.27.3"
  },
  "scripts": {
    "dev": "bun --bun vite build && (bun --bun vite build --watch & wrangler dev -c wrangler.dev.toml)",
    "dev:client": "bun --bun vite",
    "build": "bun run build:client",
    "build:client": "bun --bun vite build",
    "seed:scroll": "bash scripts/seed-scroll-data.sh",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "deploy": "bun run deploy:worker",
    "deploy:upload": "wrangler versions upload",
    "deploy:worker": "bun run db:migrate && wrangler deploy --keep-vars",
    "lint": "bun --bun oxlint src test",
    "typecheck": "tsc --noEmit",
    "test": "bun run scripts/run-vitest.ts",
    "test:components": "vitest run -c vitest.component.config.ts",
    "test:ui": "bun run build:client && playwright test -c playwright.config.ts",
    "test:ui:update": "bun run build:client && playwright test -c playwright.config.ts --update-snapshots",
    "openapi:generate": "bun --bun src/presentation/openapi/generate-cli-openapi.ts",
    "openapi:check": "bun --bun src/presentation/openapi/check-cli-openapi.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.0",
    "@cloudflare/workers-types": "^4.20250305.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "agent-browser": "^0.27.1",
    "jsdom": "^29.1.1",
    "oxlint": "^1.51.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.0",
    "wrangler": "^4.88.0"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@cloudflare/workers-oauth-provider": "^0.8.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/zod-openapi": "^1.3.0",
    "@modelcontextprotocol/hono": "^2.0.0-alpha.2",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tiptap/extension-image": "3.26.1",
    "@tiptap/extension-mention": "3.26.1",
    "@tiptap/markdown": "3.26.1",
    "@tiptap/react": "3.26.1",
    "@tiptap/starter-kit": "3.26.1",
    "@tiptap/suggestion": "3.26.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "i18next": "^26.2.0",
    "lucide-react": "^1.12.0",
    "neverthrow": "^8.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.2"
  },
  "cloudflare": {
    "bindings": {
      "ACCESS_AUD": {
        "description": "Cloudflare Access Application Audience (AUD) tag. Find it in Zero Trust > Access > Applications > your tatsumaki application."
      },
      "ACCESS_TEAM_DOMAIN": {
        "description": "Cloudflare Access team domain, for example `your-team.cloudflareaccess.com`. Find it in Zero Trust settings."
      }
    }
  }
}
