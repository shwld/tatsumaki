{
  "openapi": "3.0.3",
  "info": {
    "title": "tatsumaki CLI API",
    "version": "0.0.5"
  },
  "components": {
    "schemas": {
      "StoryGetResponse": {
        "type": "object",
        "properties": {
          "story": {
            "$ref": "#/components/schemas/Story"
          }
        },
        "required": ["story"]
      },
      "Story": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "01KNCFJZJ0Z74X92QPCE0D9MK8"
          },
          "storyNumber": {
            "type": "number",
            "example": 95
          },
          "title": {
            "type": "string",
            "example": "CLIを用意する"
          },
          "status": {
            "type": "string",
            "example": "Started"
          },
          "type": {
            "type": "string",
            "example": "feature"
          }
        },
        "required": ["id", "storyNumber", "title", "status", "type"]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/programmatic-api/v1/projects/{projectId}/stories/{storyNumber}": {
      "get": {
        "operationId": "getStoryByNumber",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "example": "project-123"
            },
            "required": true,
            "name": "projectId",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "example": "95"
            },
            "required": true,
            "name": "storyNumber",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Story found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoryGetResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Story not found"
          }
        }
      }
    }
  },
  "webhooks": {}
}
